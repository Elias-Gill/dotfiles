#!/usr/bin/env bash

if [[ $# -eq 1 ]]; then
    selected=$(realpath "$1")
else
    selected=$(
        {
            # Recursive folders using fd
            fd -t d -a . ~/Proyectos --max-depth 2 --exclude node_modules
            fd -t d -a . ~/facultad --max-depth 1 --exclude node_modules
            fd -t d -a . ~/Fecoprod --max-depth 2 --exclude node_modules
            fd -t d -a . ~/Documentos --max-depth 3 --exclude node_modules

            # Manual entries
            printf "%s\n" ~/Fecoprod
        } |
        sort -u |
        fzf \
            --scheme=history \
            --preview 'tree -L 1 --dirsfirst -C {}' \
            --preview-window=40%
    )
fi

# quit if nohting is selected
[[ -z "$selected" ]] && exit 0

clean_name() {
    local name="$1"

    printf '%s\n' "$name" |
        sed -E 's/[[:space:]]+/_/g; s/[^a-zA-Z0-9_-]//g'
}

# Extract selected folders names
base_name=$(basename "$selected")
parent_name=$(basename "$(dirname "$selected")")

base_clean=$(clean_name "$base_name")
parent_clean=$(clean_name "$parent_name")

# generate a new session name based on the parent name and the selected folder
if [[ "$parent_clean" != "$(basename "$HOME")" ]]; then
    selected_name="${base_clean} (${parent_clean})"
else
    selected_name="$base_clean"
fi

# keep names short
selected_name=${selected_name:0:50}

# if no name is set, then create an unnamed session
[[ -z "$selected_name" ]] && selected_name="unnamed_session"

# Create session if not exists
if ! tmux has-session -t="$selected_name" 2>/dev/null; then
    tmux new-session -ds "$selected_name" -c "$selected"
fi

# attach to server/session
if [[ -n "$TMUX" ]]; then
    tmux switch-client -t "$selected_name"
else
    exec tmux attach-session -t "$selected_name"
fi
