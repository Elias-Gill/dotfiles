#!/usr/bin/env bash

list_sessions() {
    current=$(tmux display-message -p '#S' 2>/dev/null)

    tmux list-sessions -F '#S' |
        grep -v -x "$current"

    if [[ -n "$current" ]] &&
       tmux has-session -t "$current" 2>/dev/null; then
        echo "$current"
    fi
}

export -f list_sessions

selected_name=$(
    bash -c 'list_sessions' |
    fzf \
        --no-sort \
        --layout=reverse \
        --preview 'tm-tree {}' \
        --preview-window=65% \
        --bind 'ctrl-x:execute-silent(tmux kill-session -t {})+reload(bash -c "list_sessions")'
)

[[ -z "$selected_name" ]] && exit 0

tmux switch-client -t "$selected_name"
