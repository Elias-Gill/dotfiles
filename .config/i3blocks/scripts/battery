#!/usr/bin/env python3
#
# Battery block for i3blocks - Porcentaje primero

from subprocess import check_output
import os
import re

config = dict(os.environ)
status = check_output(['acpi'], universal_newlines=True).strip()

if not status:
    fulltext = "<span color='red'><span font='FontAwesome'></span> No battery</span>"
    percentleft = 100
else:
    batteries = [b for b in status.split("\n") if b]
    state_batteries = []
    percentleft_batteries = []
    timeleft = ""

    for battery in batteries:
        if battery:
            parts = battery.split(": ")[1].split(", ")
            state_batteries.append(parts[0])
            
            # Porcentaje
            p = int(parts[1].rstrip("%"))
            if p > 0:
                percentleft_batteries.append(p)
            
            # Tiempo restante (solo del primero)
            if not timeleft and len(parts) > 2:
                time_match = re.search(r"(\d+:\d+)", parts[-1])
                if time_match:
                    timeleft = f" ({time_match.group(1)})"

    state = state_batteries[0] if state_batteries else "Unknown"
    percentleft = int(sum(percentleft_batteries) / len(percentleft_batteries)) if percentleft_batteries else 0

    # Iconos
    FA_BATTERY = "<span font='FontAwesome'></span>"
    FA_LIGHTNING = "<span color='{}'><span font='FontAwesome'></span></span>".format(config.get("color_charging", "yellow"))
    FA_PLUG = "<span font='FontAwesome'></span>"
    FA_QUESTION = "<span font='FontAwesome'></span>"

    # Definir ícono según estado
    if state == "Discharging":
        icon = FA_BATTERY
    elif state == "Charging":
        icon = FA_LIGHTNING + " " + FA_PLUG
    elif state == "Full":
        icon = FA_PLUG
    else:
        icon = FA_QUESTION + " " + FA_BATTERY

    # Función de color según porcentaje
    def get_color(percent):
        if percent < 10:
            return config.get("color_10", "#FF0000")
        if percent < 20:
            return config.get("color_20", "#FF3300")
        if percent < 30:
            return config.get("color_30", "#FF6600")
        if percent < 40:
            return config.get("color_40", "#FF9900")
        if percent < 50:
            return config.get("color_50", "#FFCC00")
        if percent < 60:
            return config.get("color_60", "#FFFF00")
        if percent < 70:
            return config.get("color_70", "#FFFF33")
        if percent < 80:
            return config.get("color_80", "#FFFF66")
        return config.get("color_full", "#FFFFFF")

    # === FORMATO FINAL: PORCENTAJE PRIMERO ===
    color = get_color(percentleft)
    fulltext = '<span color="{}">{}%</span> {}'.format(color, percentleft, icon)

print(fulltext)
print(fulltext)

if percentleft < 10:
    exit(33)
