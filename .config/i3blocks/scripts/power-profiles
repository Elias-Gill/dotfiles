#!/usr/bin/env bash

SIGNAL=5

# ==================== CLICK ====================
if [[ "$BLOCK_BUTTON" == "1" ]]; then

    perf="ïƒ§  Performance"
    balanced="ï‰Ž  Balanced"
    powersave="ïŠ™  Power Saver"

    options="$perf\n$balanced\n$powersave"

    chosen="$(echo -e "$options" | rofi \
        -dmenu \
        -i \
        -p "Power Mode" \
        -markup-rows)"

    case "$chosen" in
        "$perf")
            tlpctl set performance
            ;;
        "$balanced")
            tlpctl set balanced
            ;;
        "$powersave")
            tlpctl set power-saver
            ;;
        *)
            # no hacer nada
            BLOCK_BUTTON=0
            exec "$0"   # re-ejecutar el script para mostrar el icono
            ;;
    esac

    # wait for tlpctl
    sleep 0.5
fi

# Leer estado final
current_profile="$(tlpctl get 2>/dev/null || echo 'unknown')"

# Mostrar icono
case "$current_profile" in
    performance)
        icon="ïƒ§"
        color="#ff5555"
        ;;
    balanced)
        icon="ï‰Ž"
        color="#f1fa8c"
        ;;
    power-saver)
        icon="ïŠ™"
        color="#50fa7b"
        ;;
    *)
        icon="?"
        color="#bbbbbb"
        ;;
esac

echo "<span color=\"$color\">$icon</span>"

# Forzar actualizaciÃ³n solo cuando hubo click
[[ "$BLOCK_BUTTON" == "1" ]] && pkill -RTMIN+$SIGNAL i3blocks 2>/dev/null
